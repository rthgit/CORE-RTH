{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rth.local/schema/rth.plugin.v0.json",
  "title": "RTH Plugin Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "id",
    "name",
    "version",
    "vendor",
    "category",
    "surface",
    "compatibility_tier",
    "capabilities_requested",
    "risk_class",
    "consent_defaults",
    "supported_apps",
    "actions"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "rth.plugin.v0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]{3,80}$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "vendor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "category": {
      "type": "string",
      "enum": [
        "development",
        "office",
        "communication",
        "knowledge",
        "browser",
        "storage",
        "database",
        "ai_runtime",
        "security",
        "automation",
        "other"
      ]
    },
    "surface": {
      "type": "string",
      "enum": ["cli", "rest", "browser", "filesystem", "email", "database", "hybrid"]
    },
    "compatibility_tier": {
      "type": "string",
      "enum": ["first_class", "verified", "community", "fallback_browser"]
    },
    "supported_apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "version_range": { "type": "string", "maxLength": 80 },
          "platforms": {
            "type": "array",
            "items": { "type": "string", "enum": ["windows", "linux", "macos", "web", "cross"] }
          },
          "notes": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "capabilities_requested": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "filesystem_scan",
          "filesystem_read",
          "filesystem_write",
          "process_exec",
          "network_access",
          "system_modify",
          "data_export",
          "plugin_runtime"
        ]
      },
      "uniqueItems": true
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "consent_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proposal_required"],
      "properties": {
        "proposal_required": { "type": "boolean" },
        "dry_run_supported": { "type": "boolean" },
        "owner_approval_required": { "type": "boolean" },
        "suggested_guardian_severity_min": {
          "type": "string",
          "enum": ["lenient", "balanced", "strict", "paranoid"]
        }
      }
    },
    "config_schema": {
      "type": "object",
      "description": "JSON Schema fragment for plugin-specific config",
      "default": {}
    },
    "healthcheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["cli", "http", "script", "none"] },
        "command": { "type": "array", "items": { "type": "string" } },
        "url": { "type": "string" },
        "timeout_sec": { "type": "number", "minimum": 0.1, "maximum": 60 }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "capability", "risk"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9._-]{2,80}$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 120 },
          "capability": {
            "type": "string",
            "enum": [
              "filesystem_scan",
              "filesystem_read",
              "filesystem_write",
              "process_exec",
              "network_access",
              "system_modify",
              "data_export",
              "plugin_runtime"
            ]
          },
          "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "dry_run_supported": { "type": "boolean" },
          "description": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 1000
    }
  }
}

