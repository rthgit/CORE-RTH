# Application
APP_ENV=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rth_cortex
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/rth_cortex_test

# Security
SECRET_KEY=AIzaSyDJ-SK3nykQQFHzSa36tGWKcyfAUK1NsEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
FRONTEND_API_KEY=profquintino9

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# External Services
VECTOR_DB_URL=http://localhost:6333
LLM_API_KEY=your-llm-api-key

# Multi-Provider / Local LLM (planned UI-managed control plane; optional for now)
# Secrets can be kept out of .env via `/api/v1/secrets/*` (local secret store v0)
# Optional: force secret store backend/path
# RTH_SECRET_STORE_MODE=keyring
# RTH_SECRET_STORE_BASE=%TEMP%\\rth_core\\secrets
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
# LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
# RTH_MODEL_ROUTER_POLICY_PATH=storage_runtime/models/routing_policy.json
# RTH_MODEL_CONTROL_PLANE_BASE=%TEMP%\\rth_core\\models

# Rate Limiting
RATE_LIMIT=100/minute

# Guardian Security Policy
RTH_PROPOSAL_TTL_HOURS=24
RTH_REQUIRE_OWNER_APPROVAL=true
RTH_PROCESS_EXEC_ALLOWED_ACTIONS=app_launch,workspace_command,rth_lm_action,shadow_ccs_action

# SHADOW CCS Integration
RTH_SHADOW_ROOT=C:\Users\PC\Desktop\Biome\shadow_x_models

# Mail Bridge (optional, remote command intake)
RTH_IMAP_HOST=imap.gmail.com
RTH_IMAP_PORT=993
RTH_IMAP_USER=your-email@example.com
RTH_IMAP_PASSWORD=your-app-password
RTH_IMAP_FOLDER=INBOX
RTH_MAIL_SHARED_SECRET=change-this-secret
RTH_MAIL_ALLOWED_SENDERS=your-email@example.com
RTH_MAIL_ALLOW_APPROVE=0
RTH_MAIL_MAX_RISK=low
