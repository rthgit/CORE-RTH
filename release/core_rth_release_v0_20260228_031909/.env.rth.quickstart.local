# Core Rth - Quickstart local secrets/config (LOCAL ONLY, do not commit)
# Fill what you have now. Leave the rest empty.
# Tip: puoi lasciare vuote le credenziali qui e salvarle via `/api/v1/secrets/set`.

# -----------------------------
# GROQ (usable now via UI/API)
# -----------------------------
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Suggested Groq model sets (not auto-imported yet; I use these values to configure routing)
RTH_GROQ_MODELS_LOW_COST=gpt-oss-20b,llama-4-scout
RTH_GROQ_MODELS_REASONING=gpt-oss-120b,qwen-3-32b,kimi-k2
RTH_GROQ_MODELS_MULTIMODAL=llama-4-scout,whisper-large-v3,whisper-large-v3-turbo

# Optional provider label/id preferences
RTH_GROQ_PROVIDER_ID=groq_main
RTH_GROQ_PROVIDER_LABEL=Groq Main

# -----------------------------
# Local LLM runtime (llama.cpp)
# -----------------------------
# Force a single shared models control-plane state path across CLI/API processes.
RTH_MODEL_CONTROL_PLANE_BASE=%TEMP%\\rth_core\\models
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
RTH_LLAMA_CPP_MODEL_PATH=D:\CORE RTH\models\mini_gguf\SmolLM2-135M-Instruct-Q4_K_M.gguf

# -----------------------------
# Mail bridge (already supported)
# -----------------------------
RTH_IMAP_HOST=imap.fastmail.com
RTH_IMAP_PORT=993
RTH_IMAP_USER=your_mailbox@example.com
RTH_IMAP_PASSWORD=
RTH_IMAP_FOLDER=INBOX
RTH_MAIL_SHARED_SECRET=change_me_shared_secret
RTH_MAIL_ALLOWED_SENDERS=
RTH_MAIL_ALLOW_APPROVE=0
RTH_MAIL_MAX_RISK=low

SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
SMTP_USER=your_mailbox@example.com
SMTP_PASSWORD=
SMTP_TLS=true
EMAILS_FROM_EMAIL=your_mailbox@example.com

# -----------------------------
# Telegram (planned adapter)
# -----------------------------
RTH_TELEGRAM_BOT_TOKEN=
RTH_TELEGRAM_ALLOWED_CHAT_IDS=
RTH_TELEGRAM_WEBHOOK_SECRET=change_me_telegram_webhook_secret

# -----------------------------
# WhatsApp (planned adapter)
# Choose one provider when we wire it:
#   meta_cloud | twilio
# -----------------------------
RTH_WHATSAPP_PROVIDER=twilio

# Meta WhatsApp Cloud API
RTH_WHATSAPP_META_ACCESS_TOKEN=
RTH_WHATSAPP_META_PHONE_NUMBER_ID=
RTH_WHATSAPP_META_VERIFY_TOKEN=
RTH_WHATSAPP_ALLOWED_NUMBERS=

# Twilio WhatsApp (alternative)
RTH_TWILIO_ACCOUNT_SID=
RTH_TWILIO_AUTH_TOKEN=
RTH_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
RTH_TWILIO_WHATSAPP_ALLOWED_NUMBERS=whatsapp:+390000000000
